<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laura Stella Photography</title>
    <link rel="preconnect" href="[fonts.googleapis.com](https://fonts.googleapis.com)">
    <link rel="preconnect" href="[fonts.gstatic.com](https://fonts.gstatic.com)" crossorigin>
    <link href="[fonts.googleapis.com](https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap)" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        :root {
            --cream: #f5f0e8;
            --warm-white: #faf8f5;
            --soft-beige: #e8e0d5;
            --muted-brown: #8b7355;
            --deep-brown: #5c4a3d;
            --charcoal: #3a3a3a;
            --soft-sage: #a8b5a0;
            --dusty-rose: #c9a89a;
            --golden: #d4a574;
        }
        html {
            scroll-behavior: smooth;
        }
        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--warm-white);
            color: var(--charcoal);
            line-height: 1.6;
        }
        /* Navigation */
        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(250, 248, 245, 0.95);
            backdrop-filter: blur(10px);
            z-index: 1000;
            padding: 1.2rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--soft-beige);
        }
        .logo {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.8rem;
            font-weight: 300;
            color: var(--deep-brown);
            text-decoration: none;
            letter-spacing: 2px;
        }
        .nav-links {
            display: flex;
            gap: 2.5rem;
            list-style: none;
        }
        .nav-links a {
            text-decoration: none;
            color: var(--muted-brown);
            font-size: 0.85rem;
            font-weight: 400;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            transition: color 0.3s ease;
        }
        .nav-links a:hover {
            color: var(--deep-brown);
        }
        .menu-toggle {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            padding: 5px;
        }
        .menu-toggle span {
            width: 25px;
            height: 2px;
            background: var(--muted-brown);
            transition: all 0.3s ease;
        }
        /* Hero Section */
        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: linear-gradient(135deg, var(--cream) 0%, var(--warm-white) 50%, var(--soft-beige) 100%);
            position: relative;
            overflow: hidden;
        }
        .hero::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(ellipse at center, transparent 0%, var(--warm-white) 70%);
            opacity: 0.5;
        }
        .hero-content {
            position: relative;
            z-index: 1;
            padding: 2rem;
        }
        .hero h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 4.5rem;
            font-weight: 300;
            color: var(--deep-brown);
            margin-bottom: 1rem;
            letter-spacing: 8px;
            line-height: 1.2;
        }
        .hero .subtitle {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.5rem;
            font-style: italic;
            color: var(--muted-brown);
            margin-bottom: 2rem;
            font-weight: 300;
        }
        .hero p {
            font-size: 0.9rem;
            color: var(--muted-brown);
            max-width: 500px;
            margin: 0 auto 2.5rem;
            letter-spacing: 0.5px;
            line-height: 1.8;
        }
        .btn {
            display: inline-block;
            padding: 1rem 2.5rem;
            background: transparent;
            border: 1px solid var(--muted-brown);
            color: var(--muted-brown);
            text-decoration: none;
            font-size: 0.8rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            transition: all 0.4s ease;
        }
        .btn:hover {
            background: var(--muted-brown);
            color: var(--warm-white);
        }
        /* Section Styles */
        section {
            padding: 6rem 2rem;
        }
        .section-header {
            text-align: center;
            margin-bottom: 4rem;
        }
        .section-header h2 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.8rem;
            font-weight: 300;
            color: var(--deep-brown);
            margin-bottom: 1rem;
            letter-spacing: 4px;
        }
        .section-header .divider {
            width: 60px;
            height: 1px;
            background: var(--golden);
            margin: 1.5rem auto;
        }
        .section-header p {
            color: var(--muted-brown);
            font-size: 0.95rem;
            max-width: 600px;
            margin: 0 auto;
            font-style: italic;
            font-family: 'Cormorant Garamond', serif;
        }
        /* About Section */
        .about {
            background: var(--cream);
        }
        .about-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            max-width: 1200px;
            margin: 0 auto;
            align-items: center;
        }
        .about-image {
            position: relative;
        }
        .about-image .frame {
            position: absolute;
            top: -20px;
            left: -20px;
            right: 20px;
            bottom: 20px;
            border: 1px solid var(--golden);
            z-index: 0;
        }
        .about-image img {
            width: 100%;
            height: 500px;
            object-fit: cover;
            position: relative;
            z-index: 1;
            filter: sepia(10%) brightness(1.02);
        }
        .about-text h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            font-weight: 300;
            color: var(--deep-brown);
            margin-bottom: 1.5rem;
            letter-spacing: 2px;
        }
        .about-text p {
            color: var(--charcoal);
            margin-bottom: 1.5rem;
            font-size: 0.95rem;
            line-height: 1.9;
        }
        .signature {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            font-style: italic;
            color: var(--muted-brown);
            margin-top: 2rem;
        }
        /* Portfolio Section */
        .portfolio {
            background: var(--warm-white);
        }
        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            max-width: 1400px;
            margin: 0 auto;
        }
        .portfolio-item {
            position: relative;
            overflow: hidden;
            aspect-ratio: 1;
            cursor: pointer;
        }
        .portfolio-item:nth-child(1) {
            grid-column: span 2;
            grid-row: span 2;
            aspect-ratio: auto;
        }
        .portfolio-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease, filter 0.4s ease;
            filter: sepia(8%) contrast(0.95) brightness(1.02);
        }
        .portfolio-item:hover img {
            transform: scale(1.05);
            filter: sepia(0%) contrast(1) brightness(1);
        }
        .portfolio-item .overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(92, 74, 61, 0.7) 0%, transparent 60%);
            opacity: 0;
            transition: opacity 0.4s ease;
            display: flex;
            align-items: flex-end;
            padding: 2rem;
        }
        .portfolio-item:hover .overlay {
            opacity: 1;
        }
        .overlay-text {
            color: var(--warm-white);
        }
        .overlay-text h4 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.4rem;
            font-weight: 400;
            margin-bottom: 0.3rem;
            letter-spacing: 1px;
        }
        .overlay-text span {
            font-size: 0.75rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            opacity: 0.9;
        }
        /* Services Section */
        .services {
            background: var(--soft-beige);
        }
        .services-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }
        .service-card {
            background: var(--warm-white);
            padding: 3rem 2rem;
            text-align: center;
            transition: transform 0.4s ease, box-shadow 0.4s ease;
        }
        .service-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(92, 74, 61, 0.1);
        }
        .service-icon {
            width: 60px;
            height: 60px;
            margin: 0 auto 1.5rem;
            border: 1px solid var(--golden);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .service-icon svg {
            width: 28px;
            height: 28px;
            stroke: var(--muted-brown);
        }
        .service-card h4 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.5rem;
            font-weight: 400;
            color: var(--deep-brown);
            margin-bottom: 1rem;
            letter-spacing: 1px;
        }
        .service-card p {
            color: var(--muted-brown);
            font-size: 0.9rem;
            line-height: 1.8;
            margin-bottom: 1.5rem;
        }
        .service-card .price {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.2rem;
            color: var(--golden);
            font-style: italic;
        }
        /* Testimonials */
        .testimonials {
            background: var(--cream);
            text-align: center;
        }
        .testimonial-slider {
            max-width: 800px;
            margin: 0 auto;
        }
        .testimonial {
            padding: 2rem;
        }
        .testimonial-quote {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.6rem;
            font-style: italic;
            color: var(--charcoal);
            line-height: 1.8;
            margin-bottom: 2rem;
        }
        .testimonial-quote::before {
            content: '"';
            font-size: 4rem;
            color: var(--golden);
            display: block;
            margin-bottom: -1rem;
            font-family: Georgia, serif;
        }
        .testimonial-author {
            font-size: 0.85rem;
            color: var(--muted-brown);
            letter-spacing: 2px;
            text-transform: uppercase;
        }
        /* Contact Section */
        .contact {
            background: var(--warm-white);
        }
        .contact-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            max-width: 1100px;
            margin: 0 auto;
        }
        .contact-info h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            font-weight: 300;
            color: var(--deep-brown);
            margin-bottom: 1.5rem;
            letter-spacing: 2px;
        }
        .contact-info p {
            color: var(--muted-brown);
            margin-bottom: 2rem;
            line-height: 1.8;
        }
        .contact-details {
            list-style: none;
        }
        .contact-details li {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
            color: var(--charcoal);
            font-size: 0.95rem;
        }
        .contact-details svg {
            width: 20px;
            height: 20px;
            stroke: var(--golden);
        }
        .social-links {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
        }
        .social-links a {
            width: 45px;
            height: 45px;
            border: 1px solid var(--soft-beige);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }
        .social-links a:hover {
            background: var(--muted-brown);
            border-color: var(--muted-brown);
        }
        .social-links a:hover svg {
            stroke: var(--warm-white);
        }
        .social-links svg {
            width: 20px;
            height: 20px;
            stroke: var(--muted-brown);
        }
        .contact-form input,
        .contact-form textarea {
            width: 100%;
            padding: 1rem;
            border: 1px solid var(--soft-beige);
            background: transparent;
            font-family: 'Montserrat', sans-serif;
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
            transition: border-color 0.3s ease;
            color: var(--charcoal);
        }
        .contact-form input:focus,
        .contact-form textarea:focus {
            outline: none;
            border-color: var(--muted-brown);
        }
        .contact-form input::placeholder,
        .contact-form textarea::placeholder {
            color: var(--muted-brown);
            letter-spacing: 1px;
        }
        .contact-form textarea {
            height: 150px;
            resize: none;
        }
        .contact-form button {
            width: 100%;
            padding: 1rem 2rem;
            background: var(--muted-brown);
            border: none;
            color: var(--warm-white);
            font-family: 'Montserrat', sans-serif;
            font-size: 0.85rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            cursor: pointer;
            transition: background 0.3s ease;
        }
        .contact-form button:hover {
            background: var(--deep-brown);
        }
        /* Footer */
        footer {
            background: var(--deep-brown);
            color: var(--cream);
            padding: 3rem 2rem;
            text-align: center;
        }
        footer .logo {
            color: var(--cream);
            display: block;
            margin-bottom: 1rem;
        }
        footer p {
            font-size: 0.8rem;
            opacity: 0.8;
            letter-spacing: 1px;
        }
        /* Responsive */
        @media (max-width: 1024px) {
            .portfolio-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .portfolio-item:nth-child(1) {
                grid-column: span 1;
                grid-row: span 1;
                aspect-ratio: 1;
            }
            .services-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        @media (max-width: 768px) {
            .nav-links {
                display: none;
                position: absolute;
                top: 100%;
                left: 0;
                right: 0;
                background: var(--warm-white);
                flex-direction: column;
                padding: 2rem;
                gap: 1.5rem;
                text-align: center;
                border-bottom: 1px solid var(--soft-beige);
            }
            .nav-links.active {
                display: flex;
            }
            .menu-toggle {
                display: flex;
            }
            .hero h1 {
                font-size: 2.8rem;
                letter-spacing: 4px;
            }
            .hero .subtitle {
                font-size: 1.2rem;
            }
            .about-content {
                grid-template-columns: 1fr;
                gap: 3rem;
            }
            .about-image {
                order: -1;
            }
            .portfolio-grid {
                grid-template-columns: 1fr;
            }
            .services-grid {
                grid-template-columns: 1fr;
            }
            .contact-content {
                grid-template-columns: 1fr;
                gap: 3rem;
            }
            .section-header h2 {
                font-size: 2rem;
            }
        }
        /* Animations */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .fade-in {
            animation: fadeInUp 0.8s ease forwards;
        }
    </style>
</head>
